<section class="max-w-4xl space-y-8">
  <div class="border-b border-gray-200 pb-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="min-w-0">
        <h1 class="text-4xl font-bold text-slate-900"><%= @resource.name %></h1>
        <p class="mt-4 text-lg leading-8 text-gray-700"><%= @resource.description.presence || "No description available." %></p>
      </div>

      <% if @resource.manageable_by?(current_user) %>
        <div class="flex-shrink-0">
          <%= link_to "Edit resource", edit_admin_resource_path(@resource), class: "inline-flex items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-2xl font-semibold text-slate-900">Author</h2>
    <% if @resource.author.present? %>
      <p class="mt-3 text-gray-700">
        By <%= link_to @resource.author.pen_name, author_path(@resource.author), class: "font-medium text-blue-700 hover:text-blue-800" %>
      </p>
    <% else %>
      <p class="mt-3 text-gray-500">No author linked to this resource.</p>
    <% end %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-2xl font-semibold text-slate-900">Included in phases</h2>

    <% if @resource.phases.any? %>
      <div class="mt-4 flex flex-wrap gap-2">
        <% @resource.phases.each do |phase| %>
          <%= link_to "##{phase.name}", phase_path(phase), class: "inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-700 hover:bg-blue-200" %>
        <% end %>
      </div>
    <% else %>
      <p class="mt-3 text-gray-500">This resource is not currently included in any phases.</p>
    <% end %>
  </div>
</section>