<div class="max-w-5xl space-y-8">
  <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h1 class="text-4xl font-bold text-slate-900"><%= @author.pen_name %></h1>
        <p class="mt-2 text-sm text-gray-600"><%= @author.information.presence || "No profile details provided." %></p>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= link_to "Edit author", edit_admin_author_path(@author), class: "inline-flex items-center rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
        <%= link_to "Back to authors", admin_authors_path, class: "inline-flex items-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
      </div>
    </div>
  </section>

  <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="flex items-center justify-between gap-4">
      <div>
        <h2 class="text-2xl font-semibold text-slate-900">Resources</h2>
        <p class="text-sm text-gray-500"><%= pluralize(@resources.count, "resource") %> for this author</p>
      </div>
    </div>

    <% if @resources.present? %>
      <div class="mt-6 space-y-4">
        <% @resources.each do |resource| %>
          <article class="rounded-lg border border-gray-200 bg-slate-50 p-4">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="text-lg font-semibold text-slate-900"><%= resource.name %></h3>
                <p class="mt-1 text-sm leading-6 text-gray-600"><%= resource.description.presence || "No description available." %></p>
              </div>

              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-full bg-white px-3 py-1 text-sm font-medium capitalize text-slate-700"><%= resource.status %></span>
                <%= link_to "View resource", resource_path(resource), class: "inline-flex items-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
              </div>
            </div>

            <% if resource.phases.any? %>
              <div class="mt-3 flex flex-wrap gap-2">
                <% resource.phases.each do |phase| %>
                  <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-slate-600"><%= phase.name %></span>
                <% end %>
              </div>
            <% end %>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-6 rounded-lg border border-dashed border-gray-300 bg-white p-6 text-sm text-gray-600">
        No resources have been created for this author yet.
      </div>
    <% end %>
  </section>
</div>
