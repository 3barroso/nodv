<div class="max-w-4xl space-y-8">
  <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h1 class="text-4xl font-bold text-slate-900">Edit resource</h1>
        <p class="mt-2 text-sm text-gray-600">Update the resource details below. The description area is ready for richer markdown-based editing later.</p>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= link_to "Back to resource", resource_path(@resource), class: "inline-flex items-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
      </div>
    </div>
  </section>

  <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-2xl font-semibold text-slate-900"><%= @resource.name %></h2>
    <p class="mt-2 text-sm text-gray-500">Editing resource content for <%= @resource.author&.pen_name || "this author" %>.</p>

    <%= form_with model: [:admin, @resource], class: "mt-6 space-y-6" do |form| %>
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :name, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-slate-500" %>
      </div>

      <div>
        <%= form.label :description, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_area :description, rows: 10, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-slate-500" %>
        <p class="mt-2 text-sm text-gray-500">This field is set up as a large text area and can later be upgraded to markdown or rich text editing.</p>
      </div>

      <div>
        <%= form.label :status, class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :status, Resource.statuses.keys.map { |value| [value.titleize, value] }, {}, class: "mt-1 block rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-slate-500" %>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= form.submit "Save resource", class: "inline-flex items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
        <%= link_to "Cancel", last_request_page(admin_resources_path), class: "inline-flex items-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
      </div>
    <% end %>
  </section>
</div>