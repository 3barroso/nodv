<section class="mb-8 pb-6 border-b border-gray-300">
  <h1 class="text-4xl font-bold"><%= @author.pen_name %></h1>
</section>

<section>
  <h2 class="text-3xl font-bold mb-6">Resources</h2>
  
  <div class="space-y-8">
    <% @author.published_resources.each do |resource| %>
      <article class="pb-6 border-b border-gray-200">
        <h4 class="text-2xl font-semibold mb-3"><%= resource.name %></h4>
        
        <p class="text-gray-700 mb-4 leading-relaxed">
          <%= resource.description %>
        </p>
        
        <div class="flex flex-wrap gap-2">
          <% if resource.phases.any? %>
            <% resource.phases.each do |phase| %>
              <%= link_to "##{phase.name}", phase_path(phase), class: "inline-block px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm hover:bg-blue-200 transition" %>
            <% end %>
          <% else %>
            <span class="text-gray-400 text-sm">No phases tagged</span>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
</section>